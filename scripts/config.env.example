# Optional: YouTube section is skipped when this is empty.
YOUTUBE_API_KEY=

# Naver Blog
NAVER_ID=
NAVER_PW=
NAVER_BLOG_ID=
# Example: Develop > AI소식 (or Develop/AI소식) -> code matches "AI소식"
NAVER_CATEGORY=

# Tistory
KAKAO_EMAIL=
KAKAO_PW=
# Example: https://your-blog.tistory.com -> your-blog
TISTORY_BLOG=
# Example: Develop > AI소식 (or Develop/AI소식) -> code matches "AI소식"
TISTORY_CATEGORY=

# LLM Provider (codex or claude)
LLM_PROVIDER=codex

# GitHub API (공개 레포 검색용, 없으면 rate limit 60req/hr)
# 발급: https://github.com/settings/tokens
GITHUB_TOKEN=

# NVD API Key (보안 주간용, 없으면 rate limit 초당 5회)
# 발급: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# 발행 재시도 설정
PUBLISH_RETRY_COUNT=2
PUBLISH_RETRY_DELAY_MS=20000

# 카카오 2FA 대기 시간 (ms, 기본 3분)
KAKAO_2FA_TIMEOUT_MS=180000

# 사용할 Claude 모델명
CLAUDE_MODEL=claude-haiku-4-5-20251001
