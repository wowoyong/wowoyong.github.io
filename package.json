{
  "name": "wowoyong.github.io",
  "version": "1.0.0",
  "description": "[![Gem Version](https://img.shields.io/gem/v/jekyll-theme-chirpy)][gem]&nbsp; [![GitHub license](https://img.shields.io/github/license/cotes2020/chirpy-starter.svg?color=blue)][mit]",
  "main": "index.js",
  "scripts": {
    "test": "echo \"No automated tests configured\" && exit 0",

    "daily": "node scripts/daily-digest.js",
    "daily:dry": "node scripts/daily-digest.js --dry-run",
    "daily:force": "node scripts/daily-digest.js --force",

    "coding": "node scripts/coding-test-gen.js",
    "coding:dry": "node scripts/coding-test-gen.js --dry-run",
    "coding:force": "node scripts/coding-test-gen.js --force",

    "interview": "node scripts/interview-gen.js",
    "interview:dry": "node scripts/interview-gen.js --dry-run",
    "interview:force": "node scripts/interview-gen.js --force",

    "eng": "node scripts/eng-digest.js",
    "eng:dry": "node scripts/eng-digest.js --dry-run",
    "eng:force": "node scripts/eng-digest.js --force",

    "sec": "node scripts/sec-weekly.js",
    "sec:dry": "node scripts/sec-weekly.js --dry-run",
    "sec:force": "node scripts/sec-weekly.js --force",

    "eco": "node scripts/claude-ecosystem-weekly.js",
    "eco:dry": "node scripts/claude-ecosystem-weekly.js --dry-run",
    "eco:force": "node scripts/claude-ecosystem-weekly.js --force",

    "publish": "node scripts/publish-post.js today ai-daily",
    "publish:coding": "node scripts/publish-post.js today coding-test",
    "publish:interview": "node scripts/publish-post.js today interview",
    "publish:eng": "node scripts/publish-post.js today eng-digest",
    "publish:sec": "node scripts/publish-post.js today sec-weekly",
    "publish:eco": "node scripts/publish-post.js today claude-ecosystem",

    "publish:naver:test": "node scripts/naver-publisher.js --test",
    "publish:tistory:test": "node scripts/tistory-publisher.js --test",
    "session:keepalive": "node scripts/session-keepalive.js",
    "playwright:install": "npx playwright install chromium",

    "logs": "tail -50 scripts/logs/daily-digest.log 2>/dev/null || echo '로그 없음'",
    "logs:err": "grep -i 'error\\|fail\\|fatal' scripts/logs/*.log 2>/dev/null | tail -20 || echo '에러 없음'"
  },
  "repository": {
    "type": "git",
    "url": "git@github-wowoyong:wowoyong/wowoyong.github.io.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
